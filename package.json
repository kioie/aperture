{
  "name": "@kioie/aperture",
  "version": "0.1.8",
  "description": "Budget-aware code context bundles for coding agents — graph resonance selection with citations, MCP-native. Works with Cursor, Claude Code, and any MCP client.",
  "homepage": "https://github.com/kioie/aperture#readme",
  "bugs": {
    "url": "https://github.com/kioie/aperture/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.kioie/aperture",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kioie/aperture.git"
  },
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aperture": "dist/cli/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts",
    "server.json",
    "tests/fixtures/sample-repo",
    "tests/fixtures/monorepo",
    "tests/fixtures/python-repo",
    "llms.txt",
    "AGENTS.md",
    "docs",
    "integrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx eval/runner.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "sync:server": "node scripts/sync-server-json.mjs",
    "prepublishOnly": "node scripts/sync-server-json.mjs && npm run build && npm test && npm run eval"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-registry",
    "cursor",
    "claude-code",
    "codex",
    "ai-agents",
    "coding-agent",
    "agent-tools",
    "context-engineering",
    "context-window",
    "code-intelligence",
    "code-context",
    "token-budget",
    "token-optimization",
    "llm",
    "openai",
    "anthropic",
    "aperture"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
